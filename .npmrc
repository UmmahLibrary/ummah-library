auto-install-peers=true
strict-peer-dependencies=false

# Keep React typings isolated per app. The web app uses React 19 and the mobile
# app uses React 18; hoisting @types/react to the root node_modules makes tsc
# see both copies at once and produces spurious "ReactNode is not assignable"
# errors. Exclude them from public hoisting so each app resolves its own.
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=!@types/react
public-hoist-pattern[]=!@types/react-dom

{
  "name": "ummah-library",
  "version": "0.0.0",
  "private": true,
  "description": "Ummah Library — an open-source Quran platform and Islamic knowledge ecosystem.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "node scripts/dev-local.mjs --web-only",
    "dev:mobile": "node scripts/dev-local.mjs --mobile-only",
    "dev:local": "node scripts/dev-local.mjs",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,md,json,yml,yaml}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,md,json,yml,yaml}\" --ignore-path .prettierignore",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.3",
      "@types/react-dom": "19.2.3"
    }
  }
}

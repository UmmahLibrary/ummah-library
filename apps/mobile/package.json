{
  "name": "@ummahlibrary/mobile",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "assets": "node scripts/gen-assets.mjs",
    "bundle": "expo export --platform android",
    "clean": "rm -rf .turbo .expo node_modules"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@ummahlibrary/core": "workspace:*",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-clipboard": "~8.0.8",
    "expo-location": "^56.0.16",
    "expo-sensors": "^56.0.5",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.2.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  },
  "expo": {
    "install": {
      "//": "react-native 0.81 peer-requires @types/react 19.2.x, newer than the SDK's pin.",
      "exclude": [
        "@types/react"
      ]
    }
  }
}

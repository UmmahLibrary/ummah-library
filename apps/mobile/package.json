{
  "name": "@ummahlibrary/mobile",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc --noEmit",
    "assets": "node scripts/gen-assets.mjs",
    "bundle": "expo export --platform android",
    "clean": "rm -rf .turbo .expo node_modules"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@ummahlibrary/core": "workspace:*",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.2.0",
    "typescript": "^5.9.2"
  },
  "expo": {
    "install": {
      "//": "react-native 0.81 peer-requires @types/react 19.2.x, newer than the SDK's pin.",
      "exclude": ["@types/react"]
    }
  }
}

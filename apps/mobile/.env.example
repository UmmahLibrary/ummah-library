# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.

# Point the mobile app at a local web server instead of production.
# Expo inlines EXPO_PUBLIC_* vars at JS bundle time, so restart Metro
# (pnpm dev) after changing this file.
#
# "localhost" does NOT work on a physical device or Android emulator —
# use your machine's LAN IP (e.g. http://192.168.1.42:3000/api/v1) or
# run `pnpm --filter @ummahlibrary/mobile dev --tunnel` (needs @expo/ngrok).
#
# Leave unset (or delete this line) to use the production API.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:3000/api/v1
